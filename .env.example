# Monarch Money MCP Server Configuration
# Copy this file to .env and fill in your actual credentials

# Required: Your Monarch Money login credentials
MONARCH_EMAIL=your-email@example.com
MONARCH_PASSWORD=your-monarch-password

# Optional but recommended: MFA secret key for two-factor authentication
# Get this from your authenticator app's QR code or setup process
MONARCH_MFA_SECRET=your-mfa-secret-key

# Optional: HTTP proxy port (default: 8765)
# Used by monarch_http_proxy.py for remote access over Tailscale
MONARCH_PROXY_PORT=8765

# Example:
# MONARCH_EMAIL=john.doe@gmail.com
# MONARCH_PASSWORD=MySecurePassword123
# MONARCH_MFA_SECRET=JBSWY3DPEHPK3PXP